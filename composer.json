{
    "name": "spatie/elasticsearch-search-string-parser",
    "description": "Build Elasticsearch queries based of a query string",
    "keywords": [
        "spatie"
    ],
    "homepage": "https://github.com/spatie/elasticsearch-search-string-parser",
    "license": "MIT",
    "authors": [
        {
            "name": "Alex Vanderbist",
            "email": "alex.vanderbist@gmail.com",
            "role": "Developer"
        },
        {
            "name": "Ruben Van Assche",
            "email": "ruben@spatie.be",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "elasticsearch/elasticsearch": "^8.0",
        "illuminate/collections": "^11.0|^12.0|^13.0",
        "spatie/elasticsearch-query-builder": "^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nyholm/psr7": "^1.0",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Spatie\\ElasticsearchStringParser\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Spatie\\ElasticsearchStringParser\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
